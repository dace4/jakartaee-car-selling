# ====================================================================
# 1. Compiled source / Binary folders
# ====================================================================
# You almost NEVER want to track the bin folder
/bin/
/obj/
/out/
/build/

# ====================================================================
# 2. macOS specific files
# These are hidden files your Mac generates automatically
# ====================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ====================================================================
# 3. IDE and Editor directories
# Prevents your personal editor settings from overriding your team's
# ====================================================================
.vscode/
.idea/
*.swp
*.suo
*.user

# Eclipse IDE files
.project
.classpath
.settings/

# ====================================================================
# 4. Logs and databases
# ====================================================================
*.log
*.sqlite
/target/

# ====================================================================
# 5. JakartaEE Environment / Server & DB Ignores
# ====================================================================
# Ignore the entire WildFly application server runtime and log folders
tools/wildfly-27.0.0.Final/

# Ignore the HSQLDB tool binaries
tools/hsqldb/

# Ignore the active database files, logs, and locks inside the db directory
# (This keeps your setup scripts safe while ignoring the volatile DB files)
database/db/

# Global Maven/Gradle build directory ignores for any sub-projects (like Car-Selling)
**/target/
**/*.war
**/*.ear
**/*.jar